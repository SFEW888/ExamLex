{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vocab-estimate-result.schema.json",
  "title": "Vocabulary Estimate Result",
  "type": "object",
  "required": ["learner_id", "test_date", "method", "estimated_vocabulary", "confidence_interval", "false_alarm_rate", "by_band"],
  "properties": {
    "learner_id": {
      "type": "string",
      "description": "Learner identifier"
    },
    "test_date": {
      "type": "string",
      "format": "date",
      "description": "Date the test was taken"
    },
    "method": {
      "const": "yes-no-sampling",
      "description": "Estimation method used"
    },
    "estimated_vocabulary": {
      "type": "integer",
      "minimum": 0,
      "maximum": 30000,
      "description": "Estimated total vocabulary size"
    },
    "confidence_interval": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "integer" },
      "description": "95% confidence interval [lower, upper]"
    },
    "false_alarm_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Rate at which non-words were claimed as known"
    },
    "by_band": {
      "type": "object",
      "patternProperties": {
        "^\\d+-\\d+\\+?$": {
          "type": "object",
          "required": ["tested", "claimed", "estimated"],
          "properties": {
            "tested": { "type": "integer", "minimum": 0 },
            "claimed": { "type": "integer", "minimum": 0 },
            "hit_rate": { "type": "number", "minimum": 0, "maximum": 1 },
            "false_alarm_rate": { "type": "number", "minimum": 0, "maximum": 1 },
            "adjusted_rate": { "type": "number", "minimum": 0, "maximum": 1 },
            "estimated": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
