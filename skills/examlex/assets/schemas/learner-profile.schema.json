{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Learner Profile",
  "type": "object",
  "required": [
    "learner_id",
    "exam_type",
    "foundation_level",
    "target_band",
    "daily_time_budget_minutes"
  ],
  "properties": {
    "learner_id": {
      "type": "string"
    },
    "exam_type": {
      "type": "string",
      "enum": [
        "CET4",
        "CET6",
        "POSTGRADUATE_ENGLISH",
        "TEM4",
        "TEM8"
      ]
    },
    "foundation_level": {
      "type": "string",
      "enum": [
        "基础偏弱",
        "中等基础",
        "基础较好"
      ]
    },
    "target_band": {
      "type": "string",
      "enum": [
        "425~499",
        "500~550",
        "550+",
        "600+",
        "50+",
        "60~69",
        "70~79",
        "70~80",
        "80+",
        "90+"
      ]
    },
    "daily_time_budget_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "exam_date": {
      "type": "string"
    }
  }
}
