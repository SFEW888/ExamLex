{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vocabulary-block.schema.json",
  "title": "ExamLex detailed memorization vocabulary block",
  "type": "object",
  "required": ["sequence", "headword", "phonetics", "senses", "memory", "example", "word_family"],
  "properties": {
    "sequence": {"type": "integer", "minimum": 1},
    "headword": {"type": "string", "minLength": 1},
    "phonetics": {"type": "string", "minLength": 1},
    "heat_level": {"type": "integer", "minimum": 0, "maximum": 5},
    "senses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["part_of_speech", "meanings"],
        "properties": {
          "part_of_speech": {"type": "string", "minLength": 1},
          "meanings": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
        }
      }
    },
    "memory": {
      "type": "object",
      "required": ["type", "breakdown", "explanation"],
      "properties": {
        "type": {"enum": ["word-formation", "root-affix", "association", "contrast", "etymology"]},
        "breakdown": {"type": "string", "minLength": 1},
        "explanation": {"type": "string", "minLength": 1}
      }
    },
    "example": {
      "type": "object",
      "required": ["sentence", "translation"],
      "properties": {
        "sentence": {"type": "string", "minLength": 1},
        "translation": {"type": "string", "minLength": 1},
        "exam_context": {"type": "string"}
      }
    },
    "word_family": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["word", "phonetics", "part_of_speech", "meanings"],
        "properties": {
          "word": {"type": "string", "minLength": 1},
          "phonetics": {"type": "string", "minLength": 1},
          "part_of_speech": {"type": "string", "minLength": 1},
          "meanings": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
        }
      }
    }
  }
}
