{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Exercise Record",
  "type": "object",
  "required": [
    "date",
    "exam_type",
    "module",
    "task_id",
    "duration_minutes",
    "total_items",
    "correct_items",
    "error_tags"
  ],
  "properties": {
    "date": {
      "type": "string"
    },
    "exam_type": {
      "type": "string"
    },
    "module": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "duration_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "total_items": {
      "type": "integer",
      "minimum": 1
    },
    "correct_items": {
      "type": "integer",
      "minimum": 0
    },
    "accuracy": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "error_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "next_action": {
      "type": "string"
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "strategy_revisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["strategy_id", "revision_sha256"],
        "properties": {
          "strategy_id": {"type": "string", "minLength": 1},
          "revision_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        },
        "additionalProperties": false
      }
    }
  }
}
