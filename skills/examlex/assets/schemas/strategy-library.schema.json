{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy-library.schema.json",
  "title": "Strategy Library",
  "type": "object",
  "required": ["strategies"],
  "properties": {
    "strategies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "strategy_id",
          "title",
          "exam_types",
          "modules",
          "content",
          "source_file",
          "added_at"
        ],
        "properties": {
          "strategy_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+-[a-z-]+-[a-z0-9-]+-\\d{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "source_file": {
            "type": "string",
            "minLength": 1
          },
          "source_type": {
            "type": "string",
            "enum": ["text", "book", "video", "podcast", "person", "course", "conversation"],
            "default": "text",
            "description": "策略来源类型"
          },
          "distillation_method": {
            "type": "string",
            "enum": ["book", "direct", "manual", "person", "video"],
            "default": "direct",
            "description": "蒸馏方法/工具"
          },
          "source_url": {
            "type": "string",
            "description": "原始来源 URL（视频链接/书籍 ISBN/人物主页等）"
          },
          "source_provenance": {
            "type": "object",
            "required": ["source_file", "sha256", "captured_at"],
            "properties": {
              "source_file": {"type": "string"},
              "source_url": {"type": ["string", "null"]},
              "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
              "captured_at": {"type": "string"}
            }
          },
          "added_at": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "exam_types": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["CET4", "CET6", "POSTGRADUATE_ENGLISH", "TEM4", "TEM8"]
            }
          },
          "modules": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["vocabulary", "listening", "reading", "translation", "writing", "language-knowledge", "proofreading", "dictation"]
            }
          },
          "ability_nodes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "content": {
            "type": "string",
            "minLength": 20
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ria_structure": {
            "type": "object",
            "description": "RIA++ 六段蒸馏结构 (R-原文引用/I-自述/A1-案例/A2-触发/E-执行/B-边界)",
            "properties": {
              "r_reading":      { "type": "string", "description": "R-原文引用 (<=150字)" },
              "i_interpretation": { "type": "string", "description": "I-用自己的话重述核心逻辑" },
              "a1_past":        { "type": "string", "description": "A1-书中/视频中案例" },
              "a2_trigger":     { "type": "string", "description": "A2-未来触发场景与语言信号" },
              "e_execution":    { "type": "array", "items": { "type": "string" }, "description": "E-可执行步骤" },
              "b_boundary":     { "type": "string", "description": "B-边界与盲点（什么时候不适用）" }
            }
          },
          "mental_model": {
            "type": "object",
            "description": "认知提取-心智模型 (名称/一句话/证据/应用/局限)",
            "properties": {
              "name":        { "type": "string", "description": "模型名称" },
              "one_liner":   { "type": "string", "description": "一句话描述" },
              "evidence":    { "type": "string", "description": "至少2个独立场景的引用证据" },
              "application": { "type": "string", "description": "适用的问题类型" },
              "limitations": { "type": "string", "description": "这个模型在什么情况下会失效" }
            }
          },
          "heuristic": {
            "type": "object",
            "description": "认知提取-决策启发式 (名称/规则/场景/案例)",
            "properties": {
              "name":     { "type": "string", "description": "规则名称" },
              "rule":     { "type": "string", "description": "具体规则描述" },
              "scenario": { "type": "string", "description": "应用场景" },
              "example":  { "type": "string", "description": "已知应用实例" }
            }
          },
          "darwin_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Darwin 9-dimension total score"
          },
          "lifecycle_status": {
            "type": "string",
            "enum": ["draft", "approved", "deprecated"],
            "default": "draft",
            "description": "Whether this strategy can be selected for learner plans"
          },
          "score_history": {
            "type": "array",
            "description": "Score change history across optimization rounds",
            "items": {
              "type": "object",
              "properties": {
                "version":    { "type": "integer" },
                "score":      { "type": "number" },
                "dimensions": { "type": "object" },
                "changed_at": { "type": "string", "format": "date" },
                "delta":      { "type": "number" },
                "status":     { "enum": ["improved", "reverted", "baseline"] }
              }
            }
          },
          "revisions": {
            "type": "array",
            "description": "Immutable, content-addressed snapshots of approved strategy versions",
            "items": {
              "type": "object",
              "required": ["version", "sha256", "strategy"],
              "properties": {
                "version": {"type": "integer", "minimum": 1},
                "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
                "strategy": {"type": "object"}
              }
            }
          },
          "approval_evidence": {
            "type": "object",
            "description": "Content-addressed reports used to approve this strategy",
            "required": ["strategy_sha256", "validation_sha256", "evaluation_sha256", "approved_at"],
            "properties": {
              "strategy_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
              "validation_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
              "evaluation_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
              "approved_at": {"type": "string", "format": "date-time"}
            }
          },
          "related_strategies": {
            "type": "array",
            "description": "Cross-references to related strategies",
            "items": {
              "type": "object",
              "properties": {
                "strategy_id": { "type": "string" },
                "relation":    { "enum": ["complements", "contrasts", "depends_on"] },
                "note":        { "type": "string" }
              }
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
