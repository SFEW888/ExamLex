[run]
source =
    skills/examlex
branch = true
omit =
    tests/*
    */__init__.py
    skills/examlex/scripts/vocab_data.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    raise SystemExit
show_missing = true
precision = 2
fail_under = 65

[html]
directory = htmlcov
