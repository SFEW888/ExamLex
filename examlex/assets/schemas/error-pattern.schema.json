{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "error-pattern.schema.json",
  "title": "Common Error Pattern",
  "type": "object",
  "required": ["error_patterns"],
  "properties": {
    "error_patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["pattern_id", "tag", "description_cn", "typical_examples", "exam_types", "frequency_in_corpus"],
        "properties": {
          "pattern_id": {
            "type": "string",
            "pattern": "^CN-[A-Z]{2}-[A-Z]+-\\d{3}$",
            "description": "Format: CN-{module_abbr}-{pattern_name}-{seq}"
          },
          "tag": {
            "type": "string",
            "description": "Mapped error tag from ERROR_TAG_TO_ABILITY"
          },
          "description_cn": {
            "type": "string",
            "minLength": 1,
            "description": "Error description in Chinese"
          },
          "typical_examples": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["incorrect", "correct"],
              "properties": {
                "incorrect": { "type": "string", "minLength": 1 },
                "correct": { "type": "string", "minLength": 1 },
                "note_cn": { "type": "string" }
              }
            }
          },
          "exam_types": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": ["CET4", "CET6", "POSTGRADUATE_ENGLISH", "TEM4", "TEM8"]
            }
          },
          "frequency_in_corpus": {
            "enum": ["very_high", "high", "medium", "low"]
          },
          "suggested_fix_strategy": {
            "type": "string",
            "description": "Suggested remediation strategy"
          },
          "related_tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
