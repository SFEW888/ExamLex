# English Exam AI Tutor is public-safe by default.
# Copy this file to .env only for local experiments. Never commit .env.

ENGLISH_EXAM_TUTOR_PROMPT_MODE=public-safe
ENGLISH_EXAM_TUTOR_DATA_DIR=./local/data
ENGLISH_EXAM_TUTOR_PRIVATE_PROMPT_DIR=
ENGLISH_EXAM_TUTOR_DEFAULT_EXAM=CET4
ENGLISH_EXAM_TUTOR_DEFAULT_TARGET=550+
